import {
  "moonbitlang/core/strconv",
}

options(
  "is-main": true,
  link: {
    "native": {
      "cc-link-flags": "-L/usr/local/lib -Wl,-rpath,/usr/local/lib -L/opt/homebrew/lib -Wl,-rpath,/opt/homebrew/lib -lduckdb",
      "stub-cc-flags": "-I/usr/local/include -I/opt/homebrew/include",
    },
  },
  targets: { "main.mbt": [ "native" ], "main_js.mbt": [ "js" ] },
)
